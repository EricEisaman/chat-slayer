{
  "name": "chat-slayer",
  "version": "0.0.1",
  "description": "Lightweight in-memory Matrix chat server",
  "type": "module",
  "main": "dist/chat-slayer.cjs",
  "scripts": {
    "lint": "eslint .",
    "fix": "gts fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "test": "vite-node src/config/allowedClients.test.ts && vite-node src/security/ClientAccessGate.test.ts && vite-node src/demo/demoStreamAuth.test.ts && vite-node src/demo/demoActionInput.test.ts && vite-node src/fi/cs/matrix/server/matrixRegistration.test.ts && vite-node src/fi/cs/matrix/server/roomUniqueness.test.ts && vite-node src/fi/cs/matrix/server/roomBatchRegistration.test.ts && vite-node src/fi/cs/core/requestServer/utils/RouteUtils.test.ts",
    "build": "vite build && npm run build:demo",
    "build:demo": "node demo/build.mjs",
    "dev": "npm run build:demo && vite-node src/chat-slayer.ts",
    "pkill": "node scripts/pkill-project.mjs",
    "render:gen:env": "node scripts/render-gen-env.mjs",
    "render:deploy:test": "node scripts/render-deploy-test.mjs",
    "start": "npm run dev",
    "start-prod": "npm run build:demo && node dist/chat-slayer.cjs",
    "start-prod:deploy": "NODE_ENV=production node dist/chat-slayer.cjs"
  },
  "engines": {
    "node": ">=20.19.0 <=23.x"
  },
  "author": "SIGMA PRODUCTIONS",
  "license": "MIT",
  "private": true,
  "bin": {
    "chat-slayer": "dist/chat-slayer.cjs"
  },
  "keywords": [
    "typescript",
    "backend",
    "rest",
    "nodejs",
    "matrix"
  ],
  "dependencies": {
    "@matrix-org/matrix-sdk-crypto-wasm": "^18.3.0",
    "@starfederation/datastar-sdk": "^1.0.0",
    "i18next": "^26.2.0",
    "jws": "^4.0.1",
    "lodash": "^4.18.1",
    "nodemailer": "^8.0.8",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/jws": "^3.2.11",
    "@types/lodash": "^4.17.24",
    "@types/moment-timezone": "^0.5.13",
    "@types/node": "^22.19.19",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^10.4.0",
    "glob": "^13.0.6",
    "globals": "^17.6.0",
    "gts": "^7.0.0",
    "moment-timezone": "^0.6.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "vite-node": "^6.0.0"
  }
}
