# Paste into Render Dashboard → Environment → "Add from .env"
# Phase 1: unblocks startup when TLS pin is not configured yet.
# Secret toggle: OFF for this variable.
#
# After Save → "Save, rebuild, and deploy", confirm:
#   curl -s https://chat-slayer.onrender.com/health
#
# Phase 2: npm run render:gen:env -- --url https://chat-slayer.onrender.com --write

BACKEND_TLS_PIN_ENFORCED=false
