# --- Dependencies ---
node_modules/

# --- Build & bundler (Vite 8 / Rolldown) ---
dist/
.vite/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# TypeScript incremental build info
*.tsbuildinfo

# --- Secrets & local environment (never commit) ---
.env
.env.*
!.env.example

# Keys and local credential files
*.pem
*.key
*.p12
credentials.json
secrets.json

# --- Logs & process/runtime ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
pids/
*.pid
*.pid.lock
*.seed

# --- Test & coverage ---
coverage/
*.lcov
.nyc_output/
lib-cov/

# --- Caches & temp ---
.cache/
.parcel-cache/
.npm/
.eslintcache
.stylelintcache
.temp/
tmp/
temp/
*-tmp/

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Editors & local IDE (keep shared settings in repo if you add them later) ---
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Optional: uncomment to ignore personal VS Code/Cursor workspace state
# .vscode/
# .cursor/

# --- Package manager (if you switch off npm) ---
.pnp.*
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnpm-store/
.yarn-integrity

# --- Docker / local overrides ---
docker-compose.override.yml
.docker/

# --- Misc artifacts ---
*.tgz
.node_repl_history
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
