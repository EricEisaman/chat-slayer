# Copy to .env for local development (never commit .env).

# JWT signing key. Local dev: leave unset or use the line below (auto-filled if missing).
# Render: Dashboard → Secret → 32+ random characters (openssl rand -base64 48).
# BACKEND_JWT_SECRET=local-dev-only-not-for-production-deploy-32chars
BACKEND_JWT_SECRET=

# Public URL clients use (local dev only — production requires https:// on Render)
BACKEND_PUBLIC_URL=http://localhost:8008

# Matrix server hostname (recommended on Render: your-service.onrender.com)
# BACKEND_HOSTNAME=chat-slayer.onrender.com

# HTTP listen URL; defaults to http://0.0.0.0:$PORT (Render injects PORT)
# BACKEND_URL=http://0.0.0.0:8008

# Optional seed users for local demo (user:password pairs, ;-separated). Registration is always open without this.
BACKEND_INITIAL_USERS=alice:devpassword

# Optional SMTP (may contain credentials — keep in secrets)
# BACKEND_EMAIL_CONFIG=smtp://localhost:25

BACKEND_LOG_LEVEL=DEBUG
BACKEND_HOSTNAME=localhost
BACKEND_JWT_ALG=HS256
BACKEND_DEFAULT_LANGUAGE=en

# Demo SSE (Datastar push-only UI)
# DEMO_SSE_INACTIVE_RESYNC_MINUTES=10
# DEMO_SSE_IDLE_CHECK_INTERVAL_MS=30000
# DEMO_SSE_KEEPALIVE=true

# Matrix federation second listener (off by default; Render free tier uses one port)
FEDERATION_ENABLED=false
# FEDERATION_PORT=8443

# Allowed chat clients (JSON array). Unset in local dev = allow all clients.
# CLIENT_ACCESS_ENFORCED=true
# ALLOWED_CLIENTS=[{"id":"web-demo","label":"Web demo","origins":["http://localhost:8008"],"allowWithoutOrigin":false},{"id":"ops-cli","label":"CLI","origins":[],"allowWithoutOrigin":true}]
# Production: include https://<your-service>.onrender.com in web-demo origins (also auto-added from BACKEND_PUBLIC_URL when listed).
